      "typeVersion": 4.5,
      "position": [2160, 300],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "4",
          "name": "Google Sheets"
        }
      }
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const properties = $input.all().map(p => p.json);\nconst msgData = $('Merge Contact').first().json;\n\nconst propertyList = properties.map((p, i) =>\n  `${i + 1}. ${p.Name} – ${p.Beds} bed, ${p.Baths} bath, $${p.Price} – ${p.Location}. Features: ${p.Features}`\n).join('\\n');\n\nconst systemPrompt = `You are a real estate assistant. You ONLY answer questions about the following available properties. If asked about anything outside these listings, politely say you can only help with available properties.\\n\\nAVAILABLE PROPERTIES:\\n${propertyList}\\n\\nAlways be friendly, professional and concise. Keep replies under 3 sentences.`;\n\nreturn [{\n  json: {\n    contact_id: msgData.contact_id,\n    chat_id: msgData.chat_id,\n    message_text: msgData.message_text,\n    system_prompt: systemPrompt\n  }\n}];"
      },
      "id": "h2i3j4k5-l6m7-8901-nopq-rs2345678901",
      "name": "Build Claude Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2400, 300]
    },
